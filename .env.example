# Google Sheets API Configuration
# Get these from Google Cloud Console

# Your Google Sheet ID (from the URL)
SPREADSHEET_ID=your-spreadsheet-id-here

# Option 1: Private Key (recommended)
# Get from Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_CLIENT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option 2: Full credentials JSON (base64 encoded)
# Generate from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Then encode: cat credentials.json | base64
# GOOGLE_CREDENTIALS_BASE64=your-base64-encoded-credentials